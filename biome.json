{
	"$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": false
	},
	"formatter": {
		"enabled": false
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"style": {
				"noCommonJs": "error"
			},
			"correctness": {
				"noUndeclaredDependencies": {
					"level": "error",
					"options": {
						"devDependencies": ["features/**", "scripts/**"]
					}
				}
			}
		}
	}
}
